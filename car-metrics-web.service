[Unit]
Description=Car Metrics Web Dashboard
After=network.target car-metrics.service

[Service]
Type=simple
User=dietpi
Group=dietpi
WorkingDirectory=/home/dietpi/car-metrics
ExecStart=/home/dietpi/car-metrics/venv/bin/python /home/dietpi/car-metrics/web/server.py
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

# Port and host (default: 0.0.0.0:8080)
# Environment=CM_WEB_PORT=8080
# Environment=CM_WEB_HOST=0.0.0.0

[Install]
WantedBy=multi-user.target
